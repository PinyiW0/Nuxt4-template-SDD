# === Docker 相關 ===
# 專案代號（compose 會自動補 -frontend 後綴，請勿自行加）
PROJECT_NAME=nuxt4-template
IMAGE_TAG=latest
HOST_PORT=3000

# === Nuxt Runtime Config ===
NUXT_APP_BASE_URL=/
# 統一 API domain（覆蓋 runtimeConfig.public.apiBase；預設同源相對路徑 /api）
# 只有跨網域部署（API 在別的 domain）才需要設絕對 URL，例如：
# NUXT_PUBLIC_API_BASE=https://api.example.com/api
NUXT_PUBLIC_API_BASE=/api
NUXT_PRIVATE_GOOGLE_SHEET_KEY=
